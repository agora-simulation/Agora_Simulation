# =============================================================================
# Agora — Environment Configuration
# Kopiere diese Datei nach .env und fülle die Pflichtfelder aus:
#   cp .env.example .env
# =============================================================================

# --- PFLICHT: Mindestens ein LLM-Provider ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...              # Optional: OpenAI als alternativer/zusätzlicher Provider

# --- Sicherheit ---
ADMIN_MASTER_KEY=change-me-in-production   # Für API-Key-Erstellung via POST /admin/keys
# ENCRYPTION_KEY=                          # Fernet-Key für Provider-API-Key-Verschlüsselung

# --- Datenbank (wird von docker-compose automatisch gesetzt) ---
# DATABASE_URL=postgresql://agora_user:agora_pass@localhost:5432/agora

# --- Optional ---
# CORS_ORIGINS=["https://meine-domain.de"]
# DEBUG=false
# MAX_CONCURRENT_SIMULATIONS=3
# DEFAULT_AGENT_CONCURRENT_CALLS=10
